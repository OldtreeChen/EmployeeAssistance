# =====================================================
# LINE 設定（從 LINE Developers Console 取得）
# =====================================================
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here
LINE_CHANNEL_SECRET=your_channel_secret_here

# LIFF ID（填寫工時用的 LIFF App ID）
LINE_LIFF_ID=your_liff_id_here

# =====================================================
# 資料庫設定
# =====================================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=line_punch_system

# =====================================================
# 加密金鑰（保護儲存在 DB 的員工密碼）
# 請自行產生 32 字元隨機字串：
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex').slice(0,32))"
# =====================================================
ENCRYPT_KEY=your_32_char_random_key_here____

# =====================================================
# 伺服器設定
# =====================================================
PORT=3000
NODE_ENV=production
